{
  "name": "miditar",
  "private": true,
  "version": "0.0.0",
  "description": "A mobile-friendly MIDI fretboard trainer with chord markers and guitar-channel MIDI export.",
  "homepage": "https://santismo.github.io/miditar/",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:offline": "node scripts/generate-example-song-manifest.mjs && tsc -b && vite build --mode offline --outDir miditar-offline --emptyOutDir",
    "refresh:catalogs": "node scripts/refresh-music-catalogs.mjs",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@coderline/alphatab": "^1.8.4",
    "jszip": "^3.10.1",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "spessasynth_lib": "^4.3.10",
    "three": "^0.185.1",
    "tone": "^15.1.22",
    "vexflow": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-static-copy": "^4.1.1"
  }
}
